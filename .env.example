# --- Postgres (used by docker-compose.yml in this repo) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=plcm
POSTGRES_PORT=5432

# PostgreSQL connection string used by FastAPI / Alembic
# Local (host machine): use localhost
# Docker Compose overrides this to host "db"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plcm

# JWT / auth
AUTH_SECRET_KEY=change-me-to-a-long-random-string
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# First-run default Admin user (username: admin). Set to false to skip creation.
CREATE_DEFAULT_ADMIN=true

# CORS (comma-separated origins). Leave empty to use built-in defaults.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1|192\.168\.\d+\.\d+)(:\d+)?

# File uploads
PLCM_UPLOAD_DIR=uploads

# Uvicorn (used when running `python -m app.main`)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
